{
  "name": "recipe-match-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Express backend for the Recipe Match hackathon app",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-lines=95 --test-coverage-functions=95 --test-coverage-branches=90",
    "test:live": "node --test test/liveApi.test.js"
  },
  "dependencies": {
    "@google/genai": "2.11.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  }
}
